@model IEnumerable<SistemaCitasMedicas.Models.Cita>

@{
    ViewData["Title"] = "Citas";
}

<h1>Listado de Citas</h1>

<table id="citastable" class="table">
    <thead>
        <tr>
            <th>Fecha</th>
            <th>Hora Inicio</th>
            <th>Hora Fin</th>
            <th>Paciente</th>
            <th>Médico</th>
            <th>Especialidad</th>
            <th>Estado</th>
            <th>Observaciones</th>
            <th>Cambiar Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.FechaCita.ToString("yyyy-MM-dd")</td>
                <td>@item.HoraInicio</td>
                <td>@item.HoraFin</td>
                <td>@($"{item.Solicitud?.Paciente?.Usuario?.Nombre} {item.Solicitud?.Paciente?.Usuario?.SegundoNombre} {item.Solicitud?.Paciente?.Usuario?.Apellido}")</td>
                <td>@($"{item.Medico?.Usuario?.Nombre} {item.Medico?.Usuario?.SegundoNombre} {item.Medico?.Usuario?.Apellido}")</td>
                <td>@item.Solicitud?.Especialidad?.Nombre</td>
                <td>@item.EstadoCita?.Nombre</td>
                <td>@item.Observaciones</td>

                <!-- Botón para abrir modal Cambiar Estado -->
                <td>
                    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#estadoModal-@item.IdCita">
                        Cambiar
                    </button>
                </td>

                <!-- Botón para abrir modal Cancelar -->
                <td>
                    <a asp-action="Details" asp-route-id="@item.IdCita" class="btn btn-info btn-sm">Detalles</a>

                    @if (item.EstadoCita?.Nombre != "Cancelada")
                    {
                        <button class="btn btn-danger btn-sm" data-bs-toggle="modal" data-bs-target="#cancelarModal-@item.IdCita">
                            Cancelar
                        </button>
                    }
                </td>
            </tr>

            <!-- Modal Cambiar Estado -->
            <div class="modal fade" id="estadoModal-@item.IdCita" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <form asp-action="CambiarEstado" method="post">
                            <div class="modal-header">
                                <h5 class="modal-title">Cambiar Estado</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <input type="hidden" name="idCita" value="@item.IdCita" />
                                <select name="estado" class="form-select">
                                    <option value="Confirmada">Confirmada</option>
                                    <option value="EnCurso">En curso</option>
                                    <option value="Finalizada">Finalizada</option>
                                    <option value="Cancelada">Cancelada</option>
                                </select>
                            </div>
                            <div class="modal-footer">
                                <button type="submit" class="btn btn-primary">Guardar</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Modal Cancelar -->
            <div class="modal fade" id="cancelarModal-@item.IdCita" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <form asp-action="Cancelar" method="post">
                            <div class="modal-header">
                                <h5 class="modal-title">Cancelar Cita</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <input type="hidden" name="id" value="@item.IdCita" />
                                <input type="text" name="motivo" class="form-control" placeholder="Motivo" />
                            </div>
                            <div class="modal-footer">
                                <button type="submit" class="btn btn-danger">Cancelar</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    </tbody>
</table>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#citastable').DataTable();
        });
    </script>
}
