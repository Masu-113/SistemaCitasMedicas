@model IEnumerable<SistemaCitasMedicas.Models.SolicitudCita>

@{
    ViewData["Title"] = "Mis Solicitudes";
}

<div class="container mt-4">

    <div class="card shadow-sm">

        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">
                Mis Solicitudes de Cita
            </h4>
            <a asp-action="Create"
               class="btn btn-light">

                <i class="bi bi-person-plus"></i>
                Nueva Solicitud

            </a>
        </div>

        <div class="card-body">

            <table id="solicitudcitatable"
                   class="table table-hover table-bordered align-middle">

                <thead class="table-light">
                    <tr>
                        <th>Especialidad</th>
                        <th>Fecha Deseada</th>
                        <th>Hora</th>
                        <th>Motivo</th>
                        <th>Fecha Solicitud</th>
                        <th>Estado</th>
                        <th>Respuesta Médico</th>

                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>
                                @item.Especialidad?.Nombre
                            </td>

                            <td>
                                @item.FechaDeseada.ToString("dd/MM/yyyy")
                            </td>

                            <td>
                                @item.HoraDeseada.ToString()
                            </td>

                            <td>
                                @item.Motivo
                            </td>

                            <td>
                                @item.FechaSolicitud.ToString("dd/MM/yyyy")
                            </td>

                            <td>
                                <span class="badge bg-info">
                                    @item.EstadoSolicitud?.Nombre
                                </span>
                            </td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(item.ComentarioRespuesta))
                                {
                                    <span class="text-danger fw-semibold">
                                        @item.ComentarioRespuesta
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">
                                        Sin respuesta aún
                                    </span>
                                }
                            </td>

                            <td class="text-center">

                                <a asp-action="Details"
                                   asp-route-id="@item.IdSolicitud"
                                   class="btn btn-sm btn-info"
                                   title="Ver detalle">

                                    <i class="bi bi-eye"></i>

                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

@section Scripts {

    <script>

        $(document).ready(function () {

            $('#solicitudcitatable').DataTable({

                language: {

                    search: "Buscar:",
                    lengthMenu: "Mostrar _MENU_ registros",
                    info: "Mostrando _START_ a _END_ de _TOTAL_",
                    paginate: {
                        first: "Primero",
                        last: "Último",
                        next: "Siguiente",
                        previous: "Anterior"
                    }

                }

            });

        });

    </script>

}