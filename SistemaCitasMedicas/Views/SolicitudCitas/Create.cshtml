@model SistemaCitasMedicas.Models.SolicitudCita

@{
    ViewData["Title"] = "Create";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4>Nueva Solicitud de Cita</h4>
        </div>
        <div class="card-body">
            <form asp-controller="SolicitudCitas" asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-6">
                        <!-- PACIENTE -->
                        <div class="mb-3">
                            <label asp-for="IdPaciente" class="form-label"></label>
                            <select asp-for="IdPaciente" class="form-select" asp-items="ViewBag.IdPaciente">
                                <option value="">-- Seleccione Paciente --</option>
                            </select>
                            <span asp-validation-for="IdPaciente" class="text-danger"></span>
                        </div>

                        <!-- ESPECIALIDAD -->
                        <div class="mb-3">
                            <label asp-for="IdEspecialidad" class="form-label"></label>
                            <select asp-for="IdEspecialidad" class="form-select" asp-items="ViewBag.IdEspecialidad">
                                <option value="">-- Seleccione Especialidad --</option>
                            </select>
                            <span asp-validation-for="IdEspecialidad" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <!-- FECHA DESEADA -->
                        <div class="mb-3">
                            <label asp-for="FechaDeseada" class="form-label"></label>
                            <input asp-for="FechaDeseada" type="date" class="form-control" />
                            <span asp-validation-for="FechaDeseada" class="text-danger"></span>
                        </div>

                        <!-- HORA DESEADA -->
                        <div class="mb-3">
                            <label asp-for="HoraDeseada" class="form-label"></label>
                            <input asp-for="HoraDeseada" type="time" class="form-control" />
                            <span asp-validation-for="HoraDeseada" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <!-- MOTIVO -->
                <div class="mb-3">
                    <label asp-for="Motivo" class="form-label"></label>
                    <textarea asp-for="Motivo" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Motivo" class="text-danger"></span>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">Guardar Solicitud</button>
                    <a asp-action="Index" class="btn btn-secondary">Regresar</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
