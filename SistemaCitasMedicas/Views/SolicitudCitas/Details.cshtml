@model SistemaCitasMedicas.Models.SolicitudCita

@{
    ViewData["Title"] = "Detalle de Solicitud";
}

<div class="container mt-4">

    <div class="card shadow-sm">

        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Detalle de Solicitud</h4>

            <a asp-action="Index" class="btn btn-light btn-sm">
                <i class="bi bi-arrow-left"></i> Volver
            </a>
        </div>

        <div class="card-body">

            <div class="row">

                <!-- IZQUIERDA -->
                <div class="col-md-6">

                    <div class="mb-3">
                        <label class="fw-bold">Paciente</label>
                        <div>
                            @Model.Paciente?.Usuario?.Nombre
                            @Model.Paciente?.Usuario?.Apellido
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="fw-bold">Especialidad</label>
                        <div>@Model.Especialidad?.Nombre</div>
                    </div>

                    <div class="mb-3">
                        <label class="fw-bold">Motivo</label>
                        <div>@Model.Motivo</div>
                    </div>

                </div>

                <!-- DERECHA -->
                <div class="col-md-6">

                    <div class="mb-3">
                        <label class="fw-bold">Fecha Deseada</label>
                        <div>@Model.FechaDeseada.ToString("dd/MM/yyyy")</div>
                    </div>

                    <div class="mb-3">
                        <label class="fw-bold">Hora Deseada</label>
                        <div>@Model.HoraDeseada.ToString()</div>
                    </div>

                    <div class="mb-3">
                        <label class="fw-bold">Fecha de Solicitud</label>
                        <div>@Model.FechaSolicitud.ToString("dd/MM/yyyy")</div>
                    </div>

                    <div class="mb-3">
                        <label class="fw-bold">Estado</label>
                        <div>
                            <span class="badge bg-info">
                                @Model.EstadoSolicitud?.Nombre
                            </span>
                        </div>
                    </div>

                </div>

            </div>

            <hr />

            <!-- RESPUESTA MÉDICO -->
            <div class="mt-3">

                <label class="fw-bold">Respuesta del Médico</label>

                <div class="p-3 border rounded bg-light">

                    @if (!string.IsNullOrWhiteSpace(Model.ComentarioRespuesta))
                    {
                        <span class="text-danger fw-semibold">
                            @Model.ComentarioRespuesta
                        </span>
                    }
                    else
                    {
                        <span class="text-muted">
                            Aún no hay respuesta del médico.
                        </span>
                    }

                </div>

            </div>

        </div>

    </div>

</div>