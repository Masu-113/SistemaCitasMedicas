@model IEnumerable<SistemaCitasMedicas.Models.Usuario>

@{
    ViewData["Title"] = "Usuarios";
}


<div class="container mt-4">


    <div class="card shadow-sm">


        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">


            <h4 class="mb-0">
                Lista de Usuarios
            </h4>


            <a asp-action="Create"
               class="btn btn-light">

                <i class="bi bi-person-plus"></i>
                Nuevo Usuario

            </a>


        </div>





        <div class="card-body">


            <table id="usuariosTable"
                   class="table table-hover table-bordered align-middle">


                <thead class="table-light">

                    <tr>


                        <th>
                            Nombre
                        </th>


                        <th>
                            Correo
                        </th>


                        <th>
                            Teléfono
                        </th>


                        <th>
                            Estado
                        </th>


                        <th>
                            Fecha Registro
                        </th>


                        <th>
                            Rol
                        </th>


                        <th class="text-center">
                            Acciones
                        </th>


                    </tr>

                </thead>



                <tbody>


                    @foreach (var item in Model)
                    {

                        <tr>


                            <td>

                                <strong>
                                    @item.Nombre @item.SegundoNombre @item.Apellido
                                </strong>

                            </td>




                            <td>

                                @item.Correo

                            </td>




                            <td>

                                @item.Telefono

                            </td>




                            <td>


                                @if (item.Activo)
                                {

                                    <span class="badge bg-success">
                                        Activo
                                    </span>

                                }
                                else
                                {

                                    <span class="badge bg-secondary">
                                        Inactivo
                                    </span>

                                }


                            </td>





                            <td>

                                @item.FechaRegistro.ToString("dd/MM/yyyy")

                            </td>





                            <td>

                                @item.Rol?.Nombre

                            </td>






                            <td class="text-center">

                                <a asp-action="Edit"
                                   asp-route-id="@item.IdUsuario"
                                   class="btn btn-sm btn-warning"
                                   title="Editar usuario">

                                    <i class="bi bi-pencil-square"></i>

                                </a>


                                <a asp-action="Details"
                                   asp-route-id="@item.IdUsuario"
                                   class="btn btn-sm btn-info text-white"
                                   title="Ver detalles">

                                    <i class="bi bi-eye"></i>

                                </a>



                                @if (item.Activo)
                                {

                                    <a asp-action="Delete"
                                       asp-route-id="@item.IdUsuario"
                                       class="btn btn-sm btn-danger"
                                       title="Desactivar usuario">

                                        <i class="bi bi-person-x"></i>

                                    </a>

                                }


                            </td>



                        </tr>

                    }


                </tbody>



            </table>


        </div>



    </div>



</div>





@section Scripts {


    <script>

        $(document).ready(function () {


            $('#usuariosTable').DataTable({

                language: {

                    search: "Buscar:",

                    lengthMenu:
                    "Mostrar _MENU_ registros",

                    info:
                    "Mostrando _START_ a _END_ de _TOTAL_ usuarios",

                    paginate: {

                        first: "Primero",

                        last: "Último",

                        next: "Siguiente",

                        previous: "Anterior"

                    },

                    emptyTable:
                    "No hay usuarios registrados"

                }

            });


        });


    </script>


}