@model SistemaCitasMedicas.Models.Usuario

@{
    ViewData["Title"] = "Desactivar Usuario";
}


<div class="container mt-4">

    <div class="card shadow-sm">


        <div class="card-header bg-danger text-white">

            <h4>Desactivar Usuario</h4>

        </div>



        <div class="card-body">


            <h5 class="mb-3">
                ¿Está seguro que desea desactivar este usuario?
            </h5>


            <div class="alert alert-warning">

                El usuario quedara inhabilitado.
                Su estado cambiará a <strong>Inactivo</strong> y no podrá utilizar el sistema.

            </div>




            <dl class="row">


                <dt class="col-sm-3">
                    Nombre
                </dt>

                <dd class="col-sm-9">
                    @Model.Nombre @Model.SegundoNombre @Model.Apellido
                </dd>




                <dt class="col-sm-3">
                    Correo
                </dt>

                <dd class="col-sm-9">
                    @Model.Correo
                </dd>





                <dt class="col-sm-3">
                    Teléfono
                </dt>

                <dd class="col-sm-9">
                    @Model.Telefono
                </dd>





                <dt class="col-sm-3">
                    Rol
                </dt>

                <dd class="col-sm-9">
                    @Model.Rol?.Nombre
                </dd>





                <dt class="col-sm-3">
                    Estado actual
                </dt>

                <dd class="col-sm-9">


                    @if (Model.Activo)
                    {
                        <span class="badge bg-success">
                            Activo
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">
                            Inactivo
                        </span>
                    }


                </dd>




                <dt class="col-sm-3">
                    Fecha de registro
                </dt>

                <dd class="col-sm-9">
                    @Model.FechaRegistro.ToString("dd/MM/yyyy")
                </dd>



            </dl>




            <form asp-action="Delete" method="post">


                <input type="hidden" asp-for="IdUsuario" />



                <button type="submit"
                        class="btn btn-danger">

                    <i class="bi bi-person-x"></i>
                    Desactivar Usuario

                </button>



                <a asp-action="Index"
                   class="btn btn-secondary">

                    Cancelar

                </a>


            </form>



        </div>


    </div>


</div>