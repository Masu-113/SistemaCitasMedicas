@model SistemaCitasMedicas.Models.Medico

@{
    ViewData["Title"] = "Editar Médico";

    var nombreCompleto = $"{Model.Usuario?.Nombre} {Model.Usuario?.SegundoNombre} {Model.Usuario?.Apellido}".Trim();
}

<h1>Editar Médico</h1>

<h4>Datos profesionales</h4>
<hr />

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <input type="hidden" asp-for="IdMedico" />
            <input type="hidden" asp-for="IdUsuario" />

            <div class="mb-3">
                <label class="form-label">Usuario asociado</label>
                <input type="text"
                       class="form-control"
                       value="@(string.IsNullOrWhiteSpace(nombreCompleto) ? "Sin usuario asociado" : nombreCompleto)"
                       readonly />
            </div>

            <div class="mb-3">
                <label asp-for="IdEspecialidad" class="form-label"></label>
                <select asp-for="IdEspecialidad" class="form-control" asp-items="ViewBag.IdEspecialidad"></select>
                <span asp-validation-for="IdEspecialidad" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NumeroLicencia" class="form-label"></label>
                <input asp-for="NumeroLicencia" class="form-control" />
                <span asp-validation-for="NumeroLicencia" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DuracionCitaMin" class="form-label"></label>
                <input asp-for="DuracionCitaMin" type="number" min="1" class="form-control" />
                <span asp-validation-for="DuracionCitaMin" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" asp-for="Activo" />
                <label class="form-check-label" asp-for="Activo"></label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    Guardar
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Volver a la lista
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}