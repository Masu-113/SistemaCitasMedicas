@{
    ViewData["Title"] = "Inicio";
}

<div class="home-container">
    <header class="hero-section" data-aos="fade-in">
        <div class="hero-content">
            <h1>Bienvenido a Sistema Citas Médicas</h1>
            <p>Organiza tus citas médicas de manera fácil, rápida y segura.</p>
            <a href="@Url.Action("Register", "Account")" class="btn btn-primary hero-btn" data-aos="zoom-in" data-aos-delay="300">Regístrate Ahora</a>
        </div>
    </header>

    <section class="features-section" data-aos="fade-up">
        <h2>¿Cómo funciona?</h2>
        <div class="steps-container">
            <div class="step-card" data-aos="fade-up" data-aos-delay="100">
                <div class="icon">1</div>
                <h3>Regístrate</h3>
                <p>Crea tu cuenta en segundos y accede a todas las funcionalidades.</p>
            </div>
            <div class="step-card" data-aos="fade-up" data-aos-delay="200">
                <div class="icon">2</div>
                <h3>Busca y Agenda</h3>
                <p>Explora médicos y especialidades, y agenda tu cita en línea.</p>
            </div>
            <div class="step-card" data-aos="fade-up" data-aos-delay="300">
                <div class="icon">3</div>
                <h3>Confirma y Disfruta</h3>
                <p>Recibe confirmación inmediata y gestiona tus citas fácilmente.</p>
            </div>
        </div>
    </section>

    <section class="benefits-section" data-aos="fade-up">
        <h2>Características Principales</h2>
        <div class="cards-wrapper">
            <div class="benefit-card" data-aos="fade-up" data-aos-delay="100">
                <i class="fas fa-user-plus icon"></i>
                <h4>Registro Sencillo</h4>
                <p>Un proceso de registro intuitivo para que empieces a gestionar tus citas sin demoras.</p>
            </div>
            <div class="benefit-card" data-aos="fade-up" data-aos-delay="200">
                <i class="fas fa-bell icon"></i>
                <h4>Recordatorios Inteligentes</h4>
                <p>Nunca más olvides una cita. Recibe notificaciones personalizadas a tiempo.</p>
            </div>
            <div class="benefit-card" data-aos="fade-up" data-aos-delay="300">
                <i class="fas fa-hospital-alt icon"></i>
                <h4>Acceso Médico Amplio</h4>
                <p>Explora un directorio completo de médicos y especialidades desde la comodidad de tu hogar.</p>
            </div>
        </div>
    </section>

    <section class="testimonials-section" data-aos="fade-up">
        <h2>Lo que dicen nuestros usuarios</h2>
        <div class="testimonials-container">
            <div class="testimonial-card" data-aos="fade-right" data-aos-delay="100">
                <p class="quote">"¡Es increíblemente fácil de usar! Pude agendar mi cita en cuestión de minutos, sin complicaciones."</p>
                <p class="author">- Juan P.</p>
            </div>
            <div class="testimonial-card" data-aos="fade-left" data-aos-delay="200">
                <p class="quote">"El sistema me recuerda mis citas importantes. ¡Adiós a las olvidadas! Muy recomendado."</p>
                <p class="author">- María G.</p>
            </div>
        </div>
    </section>

    <footer class="cta-footer" data-aos="fade-up">
        <p>¿Listo para organizar tu salud?</p>
        <a asp-controller="Registro" asp-action="Index" class="btn btn-secondary">
            Únete Gratis Hoy
        </a>
    </footer>
</div>
