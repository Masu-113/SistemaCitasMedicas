@model IEnumerable<SistemaCitasMedicas.Models.SolicitudCita>

@{
    ViewData["Title"] = "Solicitudes Pendientes";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Solicitudes Pendientes</h4>
        </div>

        <div class="card-body">
            <table id="solicitudmedicotable" class="table table-hover table-bordered align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Paciente</th>
                        <th>Especialidad</th>
                        <th>Fecha Deseada</th>
                        <th>Hora</th>
                        <th>Motivo</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @item.Paciente?.Usuario?.Nombre @item.Paciente?.Usuario?.Apellido
                            </td>

                            <td>
                                @item.Especialidad?.Nombre
                            </td>

                            <td>
                                @item.FechaDeseada.ToString("dd/MM/yyyy")
                            </td>

                            <td>
                                @item.HoraDeseada.ToString(@"hh\:mm")
                            </td>

                            <td>
                                @item.Motivo
                            </td>

                            <td class="text-center">
                                <button class="btn btn-sm btn-success"
                                        data-bs-toggle="modal"
                                        data-bs-target="#aceptarModal-@item.IdSolicitud">
                                    <i class="bi bi-check-circle"></i>
                                </button>

                                <button class="btn btn-sm btn-danger"
                                        data-bs-toggle="modal"
                                        data-bs-target="#cancelarModal-@item.IdSolicitud">
                                    <i class="bi bi-x-circle"></i>
                                </button>
                            </td>
                        </tr>

                        <!-- MODAL ACEPTAR -->
                        <div class="modal fade" id="aceptarModal-@item.IdSolicitud" tabindex="-1">
                            <div class="modal-dialog">
                                <div class="modal-content">

                                    <form asp-controller="SolicitudesMedico"
                                          asp-action="Aceptar"
                                          method="post">

                                        @Html.AntiForgeryToken()

                                        <div class="modal-header bg-success text-white">
                                            <h5 class="modal-title">Aceptar Solicitud</h5>
                                            <button type="button"
                                                    class="btn-close"
                                                    data-bs-dismiss="modal"></button>
                                        </div>


                                        <div class="modal-body">

                                            <input type="hidden"
                                                   name="id"
                                                   value="@item.IdSolicitud" />


                                            @if (User.IsInRole("Administrador"))
                                            {
                                                <label class="form-label">
                                                    Médico disponible
                                                </label>

                                                <select name="idMedico"
                                                        class="form-select"
                                                        required>

                                                    <option value="">
                                                        Seleccione médico
                                                    </option>


                                                    @if (ViewBag.MedicosDisponibles != null &&
                                                                                                ViewBag.MedicosDisponibles[item.IdSolicitud] != null)
                                                    {
                                                        foreach (var medico in ViewBag.MedicosDisponibles[item.IdSolicitud])
                                                        {
                                                            <option value="@medico.IdMedico">
                                                                @medico.Usuario.Nombre
                                                                @medico.Usuario.Apellido
                                                            </option>
                                                        }
                                                    }

                                                </select>
                                            }
                                            else if (User.IsInRole("Medico"))
                                            {
                                                <div class="alert alert-info">
                                                    La cita será asignada al médico actualmente logueado.
                                                </div>
                                            }


                                        </div>


                                        <div class="modal-footer">

                                            <button type="submit"
                                                    class="btn btn-success">

                                                <i class="bi bi-check-lg"></i>
                                                Aceptar

                                            </button>

                                        </div>

                                    </form>

                                </div>
                            </div>
                        </div>

                        <!-- MODAL CANCELAR -->
                        <div class="modal fade" id="cancelarModal-@item.IdSolicitud" tabindex="-1">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <form asp-controller="SolicitudesMedico"
                                          asp-action="Cancelar"
                                          method="post">

                                        @Html.AntiForgeryToken()

                                        <div class="modal-header bg-danger text-white">
                                            <h5 class="modal-title">Cancelar Solicitud</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>

                                        <div class="modal-body">
                                            <input type="hidden" name="id" value="@item.IdSolicitud" />

                                            <label class="form-label">Motivo de cancelación</label>

                                            <textarea name="motivo"
                                                  class="form-control"
                                                  rows="3"
                                                  required></textarea>
                                        </div>

                                        <div class="modal-footer">
                                            <button type="submit" class="btn btn-danger">
                                                <i class="bi bi-x-lg"></i> Cancelar
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle"></i>
                            @TempData["Error"]

                            <button type="button"
                                    class="btn-close"
                                    data-bs-dismiss="alert">
                            </button>
                        </div>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#solicitudmedicotable').DataTable({
                language: {
                    search: "Buscar:",
                    lengthMenu: "Mostrar _MENU_ registros",
                    info: "Mostrando _START_ a _END_ de _TOTAL_",
                    paginate: {
                        first: "Primero",
                        last: "Último",
                        next: "Siguiente",
                        previous: "Anterior"
                    }
                }
            });
        });
    </script>
}