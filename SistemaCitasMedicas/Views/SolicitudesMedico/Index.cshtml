@model IEnumerable<SistemaCitasMedicas.Models.SolicitudCita>

@{
    ViewData["Title"] = "Solicitudes Pendientes";
}

<h2>Solicitudes Pendientes</h2>

<table id="solicitudmedicotable" class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Paciente</th>
            <th>Especialidad</th>
            <th>Fecha Deseada</th>
            <th>Hora Deseada</th>
            <th>Motivo</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Paciente?.IdPaciente</td>
                <td>@item.Especialidad?.Nombre</td>
                <td>@item.FechaDeseada</td>
                <td>@item.HoraDeseada</td>
                <td>@item.Motivo</td>

                <td>
                    <!-- Botón para abrir modal Aceptar -->
                    <button class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#aceptarModal-@item.IdSolicitud">
                        Aceptar
                    </button>

                    <!-- Botón para abrir modal Cancelar -->
                    <button class="btn btn-danger btn-sm" data-bs-toggle="modal" data-bs-target="#cancelarModal-@item.IdSolicitud">
                        Cancelar
                    </button>
                </td>
            </tr>

            <!-- Modal Aceptar -->
            <div class="modal fade" id="aceptarModal-@item.IdSolicitud" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <form asp-action="Aceptar" method="post">
                            <div class="modal-header">
                                <h5 class="modal-title">Aceptar Solicitud</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <input type="hidden" name="id" value="@item.IdSolicitud" />

                                <select name="idMedico" class="form-select" required>
                                    <option value="">Seleccione médico disponible</option>
                                    @foreach (var medico in ViewBag.MedicosDisponibles[item.IdSolicitud])
                                    {
                                        <option value="@medico.IdMedico">
                                            @medico.Usuario.Nombre @medico.Usuario.Apellido
                                        </option>
                                    }
                                </select>
                            </div>
                            <div class="modal-footer">
                                <button type="submit" class="btn btn-success">Aceptar</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Modal Cancelar -->
            <div class="modal fade" id="cancelarModal-@item.IdSolicitud" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <form asp-action="Cancelar" method="post">
                            <div class="modal-header">
                                <h5 class="modal-title">Cancelar Solicitud</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <input type="hidden" name="id" value="@item.IdSolicitud" />
                                <input type="text" name="comentario" placeholder="Motivo cancelación" class="form-control" />
                            </div>
                            <div class="modal-footer">
                                <button type="submit" class="btn btn-danger">Cancelar</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    </tbody>
</table>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#solicitudmedicotable').DataTable();
        });
    </script>
}
