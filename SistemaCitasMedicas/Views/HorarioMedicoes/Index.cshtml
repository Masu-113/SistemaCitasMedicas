@model IEnumerable<SistemaCitasMedicas.Models.HorarioMedico>

@{
    ViewData["Title"] = "Horarios Médicos";

    var diasSemana = new Dictionary<int, string>
    {
        { 1, "Lunes" },
        { 2, "Martes" },
        { 3, "Miércoles" },
        { 4, "Jueves" },
        { 5, "Viernes" },
        { 6, "Sábado" },
        { 7, "Domingo" }
    };

    var esAdministrador = User.IsInRole("Administrador");
}

<h1>Horarios Médicos</h1>

@if (esAdministrador)
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Crear nuevo</a>
    </p>
}

<table id="horariosTable" class="table">
    <thead>
        <tr>
            <th>
                Médico
            </th>
            <th>
                Día
            </th>
            <th>
                Hora inicio
            </th>
            <th>
                Hora fin
            </th>
            <th>
                Activo
            </th>
            <th>
                Acciones
            </th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @($"{item.Medico?.Usuario?.Nombre} {item.Medico?.Usuario?.SegundoNombre} {item.Medico?.Usuario?.Apellido}")
                </td>
                <td>
                    @(diasSemana.ContainsKey(item.DiaSemana) ? diasSemana[item.DiaSemana] : "No definido")
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.HoraInicio)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.HoraFin)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Activo)
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.IdHorario">Detalles</a>

                    @if (esAdministrador)
                    {
                        <span>|</span>
                        <a asp-action="Edit" asp-route-id="@item.IdHorario">Editar</a>
                        <span>|</span>
                        <a asp-action="Delete" asp-route-id="@item.IdHorario">Eliminar</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#horariosTable').DataTable();
        });
    </script>
}